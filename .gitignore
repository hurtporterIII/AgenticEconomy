# Sync .project/sourceTexts/ folder (source text files)

# Don't sync user-specific SQLite databases
.project/*.sqlite

# Don't sync SQLite auxiliary files
.project/*.sqlite-wal
.project/*.sqlite-shm

# Don't sync user-specific files
.project/complete_drafts.txt
.project/localProjectSettings.json
.project/localProjectSwap.json
copilot-messages.log

# Archive formats
*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.bz2
*.xz

# Windows executables and installers
*.exe
*.msi
*.bat
*.cmd
*.com
*.scr
*.dll

# macOS executables and disk images
*.dmg
*.pkg

# Disk images and virtual machine files
*.iso
*.img
*.vhd
*.vmdk

# System files
.DS_Store
.project/attachments/files/**

# Local secrets and editor state (never push)
.env
.env.*
!.env.example

# Python bytecode
**/__pycache__/
*.py[cod]
.pytest_cache/

# Frontend build output
frontend/dist/

# Local action log (unbounded JSONL — never push to GitHub)
backend/store/actions.jsonl
backend/store/_tail_actions.jsonl

# Scratch / local experiment outputs
*.tmp
_space_test.tmp
full_readout.txt
chaos*.json
prelaunch_result.json
Hackathon*.docx

# Optional: local wallet / recovery material (keep out of GitHub)
wallet_setup/*.dat
wallet_setup/.env
wallet_setup/node_modules/
wallet_setup/output/
**/node_modules/

# Generative Agents: auto-generated per-file metadata (navigation is in index.md + YAML)
generative_agents/**/.meta.json
generative_agents/**/*.meta.json
generative_agents/**/__pycache__/

# Local Smallville / Reverie runtime outputs (regenerated by simulation runs)
generative_agents/environment/frontend_server/storage/
generative_agents/environment/frontend_server/temp_storage/

# Root-level per-file metadata from local tooling (keep navigation under generative_agents/)
/.meta.json
/*.meta.json
Hackathon*.docx.meta.json

# Cursor / local project metadata
.project/
.cursor/

# Tooling sidecar files (local navigation metadata — not source of truth)
**/*.meta.json
_bridge.json